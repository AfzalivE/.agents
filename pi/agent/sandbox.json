{
  "commands": {
    "blocked": [
      "npx"
    ]
  },
  "network": {
    "allowMachLookup": [
      "com.apple.CalendarAgent"
    ],
    "allowedDomains": [
      "localhost",
      "127.0.0.1",
      "github.com",
      "*.github.com",
      "*.githubusercontent.com",
      "auth.docker.io",
      "npmjs.org",
      "*.npmjs.org",
      "registry.yarnpkg.com",
      "pypi.org",
      "*.pypi.org",
      "*.pythonhosted.org",
      "sentry.io",
      "*.sentry.io",
      "datadoghq.com",
      "*.datadoghq.com",
      "datadoghq.eu",
      "*.datadoghq.eu",
      "anthropic.com",
      "*.anthropic.com",
      "claude.ai",
      "*.claude.ai",
      "openai.com",
      "*.openai.com",
      "chatgpt.com",
      "*.chatgpt.com",
      "google.com",
      "*.google.com",
      "*.googleapis.com",
      "todoist.com",
      "*.todoist.com",
      "twist.com",
      "*.twist.com",
      "doist.com",
      "*.doist.com",
      "*.gradle.org"
    ],
    "deniedDomains": [],
    "allowLocalBinding": true,
    "allowAllUnixSockets": false,
    "allowUnixSockets": [
      "/tmp",
      "/private/tmp",
      "~/.gnupg",
      "~/.orbstack/run/docker.sock",
      "/private/var/folders/*/*/T/TemporaryItems/NSIRD_cald_*",
      "/private/var/folders/*/*/T/TemporaryItems/NSIRD_cald_*/*"
    ]
  },
  "filesystem": {
    "denyRead": [
      "~/.aws"
    ],
    "denyWrite": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key",
      "~/.ssh"
    ],
    "allowGitConfig": true,
    "allowGitCommonDir": true,
    "allowWrite": [
      ".",
      "/tmp",
      "/private/tmp",
      "~/.gnupg",
      "~/.cache",
      "~/.docker",
      "~/.npm",
      "~/.pi/agent/*.lock",
      "~/.codex*",
      "~/.claude*",
      "~/.gradle",
      "/private/var/folders/*/*/T/TemporaryItems/NSIRD_cald_*",
      "/private/var/folders/*/*/T/TemporaryItems/NSIRD_cald_*/*"
    ]
  },
  "enableWeakerNestedSandbox": false,
  "enableWeakerNetworkIsolation": true
}
