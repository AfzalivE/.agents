{
  "network": {
    "allowedDomains": [
      "localhost",
      "127.0.0.1",
      "github.com",
      "*.github.com",
      "githubusercontent.com",
      "*.githubusercontent.com",
      "auth.docker.io",
      "ghcr.io",
      "docker.io",
      "*.docker.io",
      "production.cloudflare.docker.com",
      "npmjs.org",
      "*.npmjs.org",
      "registry.yarnpkg.com",
      "pypi.org",
      "*.pypi.org",
      "pythonhosted.org",
      "*.pythonhosted.org",
      "crates.io",
      "*.crates.io",
      "proxy.golang.org",
      "sum.golang.org",
      "go.dev",
      "golang.org",
      "rubygems.org",
      "*.rubygems.org",
      "sentry.io",
      "*.sentry.io",
      "datadoghq.com",
      "*.datadoghq.com",
      "datadoghq.eu",
      "*.datadoghq.eu",
      "anthropic.com",
      "*.anthropic.com",
      "claude.ai",
      "*.claude.ai",
      "openai.com",
      "*.openai.com",
      "chatgpt.com",
      "*.chatgpt.com",
      "google.com",
      "*.google.com",
      "googleapis.com",
      "*.googleapis.com",
      "todoist.com",
      "*.todoist.com",
      "twist.com",
      "*.twist.com",
      "doist.com",
      "*.doist.com"
    ],
    "deniedDomains": [],
    "allowLocalBinding": true,
    "allowUnixSockets": [
      "/tmp",
      "/private/tmp",
      "~/.gnupg",
      "~/.orbstack/run/docker.sock"
    ]
  },
  "filesystem": {
    "denyRead": [
      "~/.aws"
    ],
    "denyWrite": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key",
      "~/.ssh"
    ],
    "allowGitConfig": true,
    "allowGitCommonDir": true,
    "allowWrite": [
      ".",
      "/tmp",
      "/private/tmp",
      "~/.gnupg",
      "~/.cache",
      "~/.docker",
      "~/.npm",
      "~/.pi/agent/*.lock"
    ]
  },
  "enableWeakerNetworkIsolation": true
}
