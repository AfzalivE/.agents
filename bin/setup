#!/usr/bin/env bash
set -euo pipefail

# Set up ~/.agents in coding agents, install Tau for Pi from a local checkout,
# and install runtime npm dependencies for relevant repo packages.
#
# Source of truth:
#   - ~/.agents/AGENTS.md                 (shared instructions)
#   - ~/.agents/skills -> <Tau fork>/skills
#   - ~/.agents/pi/agent/*.json           (Pi JSON config defaults)
#   - ~/.agents/tau or $AGENTS_TAU_DIR    (local Tau checkout/fork for shared skills and Pi packages)
#
# Targets:
#   - Codex:  ~/.codex/AGENTS.md
#   - Claude: ~/.claude/CLAUDE.md + ~/.claude/skills/<skill>
#   - Pi:     ~/.pi/agent/AGENTS.md + ~/.pi/agent/*.json + local Tau package install
#
# Notes:
#   - Codex and Pi use ~/.agents/skills directly.
#   - Claude gets per-skill symlinks into ~/.claude/skills.
#   - Pi still needs the installed Tau package for extensions and themes.
#   - This script keeps ~/.agents/skills pointed at the Tau fork's skills/ directory.
#   - This script no longer syncs ~/.agents/pi/extensions into ~/.pi/agent/extensions.

# --- Config ---
readonly AGENTS_ROOT="${HOME}/.agents"
readonly AGENTS_SKILLS_DIR="${AGENTS_ROOT}/skills"
readonly AGENTS_INSTRUCTIONS_FILE="${AGENTS_ROOT}/AGENTS.md"
readonly AGENTS_PI_AGENT_DIR="${AGENTS_ROOT}/pi/agent"
readonly AGENTS_PI_EXTENSIONS_DIR="${AGENTS_ROOT}/pi/extensions"
readonly DEFAULT_TAU_HINT_DIR="${HOME}/Dev/ToolProjects/tau"
readonly PI_PACKAGE_NAME="${AGENTS_PI_PACKAGE_NAME:-tau-all-agent}"

readonly CLAUDE_SKILLS_DIR="${HOME}/.claude/skills"
readonly PI_AGENT_DIR="${HOME}/.pi/agent"
readonly PI_EXTENSIONS_DIR="${PI_AGENT_DIR}/extensions"
readonly PI_SETTINGS_FILE="${PI_AGENT_DIR}/settings.json"

readonly CODEX_INSTRUCTIONS_FILE="${HOME}/.codex/AGENTS.md"
readonly CLAUDE_INSTRUCTIONS_FILE="${HOME}/.claude/CLAUDE.md"
readonly PI_INSTRUCTIONS_FILE="${PI_AGENT_DIR}/AGENTS.md"

# --- Option defaults ---
DRY_RUN=0
YES=0
PRUNE=0
SYNC_CODEX=0
SYNC_CLAUDE=0
SYNC_PI=0
AGENT_FILTER_SET=0
TAU_SOURCE_PATH=""
TAU_DIR=""
TAU_SKILLS_DIR=""
PI_PACKAGE_DIR=""
PI_PACKAGE_INSTALL_NEEDED=0


declare -a PLAN_ACTIONS=()
declare -a PLAN_DESTS=()
declare -a PLAN_SRCS=()
declare -a INSTALL_COMMANDS=()
declare -a INSTALL_DIRS=()

# --- Main flow ---
main() {
  parse_args "$@"
  apply_default_agent_selection
  resolve_tau_paths
  validate_checkout_location
  validate_roots
  reset_sync_plan
  reset_dependency_plan
  plan_sync_changes
  plan_dependency_setup
  plan_pi_package_install
  ensure_runtime_dependencies

  if [[ "${#PLAN_ACTIONS[@]}" -eq 0 && "${#INSTALL_DIRS[@]}" -eq 0 && "${PI_PACKAGE_INSTALL_NEEDED}" -eq 0 ]]; then
    print_no_work
    return 0
  fi

  print_plan

  if [[ "${DRY_RUN}" -eq 1 ]]; then
    return 0
  fi

  confirm_apply
  preflight_apply_roots
  run_dependency_setup
  apply_sync_plan
  run_pi_package_install
  print_applied_summary
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      --yes)
        YES=1
        shift
        ;;
      --prune)
        PRUNE=1
        shift
        ;;
      --codex)
        SYNC_CODEX=1
        AGENT_FILTER_SET=1
        shift
        ;;
      --claude)
        SYNC_CLAUDE=1
        AGENT_FILTER_SET=1
        shift
        ;;
      --pi)
        SYNC_PI=1
        AGENT_FILTER_SET=1
        shift
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      *)
        echo "error: unknown argument: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
  done
}

apply_default_agent_selection() {
  if [[ "${AGENT_FILTER_SET}" -eq 0 ]]; then
    SYNC_CODEX=1
    SYNC_CLAUDE=1
    SYNC_PI=1
  fi
}

resolve_tau_paths() {
  local candidate=""

  if [[ -n "${AGENTS_TAU_DIR:-}" ]]; then
    candidate="${AGENTS_TAU_DIR}"
  elif [[ -e "${AGENTS_ROOT}/tau" ]]; then
    candidate="${AGENTS_ROOT}/tau"
  elif [[ -d "${DEFAULT_TAU_HINT_DIR}" ]]; then
    candidate="${DEFAULT_TAU_HINT_DIR}"
  fi

  if [[ -z "${candidate}" ]]; then
    return 0
  fi

  TAU_SOURCE_PATH="$(resolve_existing_path "${candidate}")"
  TAU_DIR="${TAU_SOURCE_PATH}"
  TAU_SKILLS_DIR="${TAU_SOURCE_PATH}/skills"
  PI_PACKAGE_DIR="${TAU_SOURCE_PATH}/packages/${PI_PACKAGE_NAME}"
}

validate_checkout_location() {
  local checkout_root
  checkout_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

  if [[ "${checkout_root}" != "${AGENTS_ROOT}" ]]; then
    echo "error: setup must be run from $(format_home_path "${AGENTS_ROOT}")" >&2
    exit 1
  fi
}

validate_roots() {
  validate_directory_root "${AGENTS_SKILLS_DIR}"
  validate_directory_root "${AGENTS_PI_AGENT_DIR}"
  visit_selected_target_roots validate_directory_root
  validate_tau_setup
}

validate_tau_setup() {
  if [[ -z "${TAU_DIR}" ]]; then
    echo "error: Tau checkout not found. Create ~/.agents/tau or set AGENTS_TAU_DIR." >&2
    exit 1
  fi

  if [[ ! -f "${TAU_DIR}/package.json" ]]; then
    echo "error: Tau checkout is missing package.json: $(format_home_path "${TAU_DIR}")" >&2
    exit 1
  fi

  if [[ ! -d "${TAU_SKILLS_DIR}" ]]; then
    echo "error: Tau checkout is missing skills/: $(format_home_path "${TAU_SKILLS_DIR}")" >&2
    exit 1
  fi

  if [[ "${SYNC_PI}" -ne 1 ]]; then
    return 0
  fi

  if [[ ! -d "${PI_PACKAGE_DIR}" || ! -f "${PI_PACKAGE_DIR}/package.json" ]]; then
    echo "error: Pi package not found: $(format_home_path "${PI_PACKAGE_DIR}")" >&2
    echo "hint: set AGENTS_PI_PACKAGE_NAME to a package under $(format_home_path "${TAU_DIR}/packages")" >&2
    exit 1
  fi
}

visit_selected_target_roots() {
  local callback="$1"

  if [[ "${SYNC_CODEX}" -eq 1 ]]; then
    "${callback}" "$(dirname "${CODEX_INSTRUCTIONS_FILE}")"
  fi

  if [[ "${SYNC_CLAUDE}" -eq 1 ]]; then
    "${callback}" "${CLAUDE_SKILLS_DIR}"
  fi

  if [[ "${SYNC_PI}" -eq 1 ]]; then
    "${callback}" "${PI_AGENT_DIR}"
  fi
}

reset_sync_plan() {
  PLAN_ACTIONS=()
  PLAN_DESTS=()
  PLAN_SRCS=()
  PLAN_CREATE_COUNT=0
  PLAN_REPLACE_COUNT=0
  PLAN_REMOVE_COUNT=0
}

reset_dependency_plan() {
  INSTALL_COMMANDS=()
  INSTALL_DIRS=()
  PI_PACKAGE_INSTALL_NEEDED=0
}

# --- Planning ---
plan_sync_changes() {
  plan_local_skills_sync
  plan_claude_skills_sync
  plan_instructions_sync
  plan_pi_json_sync
  plan_claude_skills_prune
  plan_pi_json_prune
  plan_pi_extensions_prune
}

plan_local_skills_sync() {
  plan_link "${TAU_SKILLS_DIR}" "${AGENTS_SKILLS_DIR}" dir
}

plan_claude_skills_sync() {
  [[ "${SYNC_CLAUDE}" -eq 1 ]] || return 0

  local skill_dir
  for skill_dir in "${TAU_SKILLS_DIR}"/*; do
    [[ -d "${skill_dir}" ]] || continue

    local skill_name
    skill_name="$(basename "${skill_dir}")"
    [[ "${skill_name}" == .* ]] && continue

    plan_link "${AGENTS_SKILLS_DIR}/${skill_name}" "${CLAUDE_SKILLS_DIR}/${skill_name}" dir
  done
}

plan_instructions_sync() {
  if [[ ! -f "${AGENTS_INSTRUCTIONS_FILE}" ]]; then
    echo "warn: $(format_home_path "${AGENTS_INSTRUCTIONS_FILE}") not found; skipping instruction sync" >&2
    return 0
  fi

  if [[ "${SYNC_CODEX}" -eq 1 ]]; then
    plan_link "${AGENTS_INSTRUCTIONS_FILE}" "${CODEX_INSTRUCTIONS_FILE}" file
  fi

  if [[ "${SYNC_CLAUDE}" -eq 1 ]]; then
    plan_link "${AGENTS_INSTRUCTIONS_FILE}" "${CLAUDE_INSTRUCTIONS_FILE}" file
  fi

  if [[ "${SYNC_PI}" -eq 1 ]]; then
    plan_link "${AGENTS_INSTRUCTIONS_FILE}" "${PI_INSTRUCTIONS_FILE}" file
  fi
}

plan_pi_json_sync() {
  [[ "${SYNC_PI}" -eq 1 ]] || return 0
  [[ -d "${AGENTS_PI_AGENT_DIR}" ]] || return 0

  local src
  for src in "${AGENTS_PI_AGENT_DIR}"/*.json; do
    [[ -f "${src}" ]] || continue

    local base
    base="$(basename "${src}")"
    [[ "${base}" == .* ]] && continue

    plan_link "${src}" "${PI_AGENT_DIR}/${base}" any
  done
}

plan_claude_skills_prune() {
  [[ "${PRUNE}" -eq 1 ]] || return 0
  [[ "${SYNC_CLAUDE}" -eq 1 ]] || return 0
  [[ -d "${CLAUDE_SKILLS_DIR}" ]] || return 0

  local entry
  for entry in "${CLAUDE_SKILLS_DIR}"/*; do
    [[ -e "${entry}" || -L "${entry}" ]] || continue

    local base
    base="$(basename "${entry}")"
    [[ "${base}" == ".system" ]] && continue

    if [[ ! -d "${TAU_SKILLS_DIR}/${base}" ]]; then
      plan_remove "${entry}"
    fi
  done
}

plan_pi_json_prune() {
  [[ "${PRUNE}" -eq 1 ]] || return 0
  [[ "${SYNC_PI}" -eq 1 ]] || return 0
  [[ -d "${PI_AGENT_DIR}" ]] || return 0

  local entry
  for entry in "${PI_AGENT_DIR}"/*.json; do
    [[ -e "${entry}" || -L "${entry}" ]] || continue
    [[ -L "${entry}" ]] || continue

    local base
    base="$(basename "${entry}")"

    if [[ -f "${AGENTS_PI_AGENT_DIR}/${base}" ]]; then
      continue
    fi

    local existing_target
    existing_target="$(readlink "${entry}")"

    case "${existing_target}" in
      */pi/agent/*.json)
        plan_remove "${entry}"
        ;;
    esac
  done
}

plan_pi_extensions_prune() {
  [[ "${PRUNE}" -eq 1 ]] || return 0
  [[ "${SYNC_PI}" -eq 1 ]] || return 0

  if [[ -L "${PI_EXTENSIONS_DIR}" ]]; then
    local existing_target
    existing_target="$(readlink "${PI_EXTENSIONS_DIR}")"
    if [[ "${existing_target}" == "${AGENTS_PI_EXTENSIONS_DIR}" ]]; then
      plan_remove "${PI_EXTENSIONS_DIR}"
    fi
  fi
}

plan_dependency_setup() {
  plan_skill_package_setups "${TAU_SKILLS_DIR}"

  if [[ -n "${TAU_DIR}" && ( "${SYNC_PI}" -eq 1 || "${SYNC_CLAUDE}" -eq 1 || "${SYNC_CODEX}" -eq 1 ) ]]; then
    plan_package_setup "${TAU_DIR}"
  fi
}

plan_skill_package_setups() {
  local skills_root="$1"
  [[ -d "${skills_root}" ]] || return 0

  local skill_dir
  for skill_dir in "${skills_root}"/*; do
    [[ -d "${skill_dir}" ]] || continue

    local package_json="${skill_dir}/package.json"
    [[ -f "${package_json}" ]] || continue

    package_has_runtime_dependencies "${package_json}" || continue
    plan_package_setup "${skill_dir}"
  done
}

plan_package_setup() {
  local package_dir="$1"
  [[ -f "${package_dir}/package.json" ]] || return 0

  if ! package_needs_setup "${package_dir}"; then
    return 0
  fi

  INSTALL_DIRS+=("${package_dir}")
  INSTALL_COMMANDS+=("$(package_install_command "${package_dir}")")
}

plan_pi_package_install() {
  [[ "${SYNC_PI}" -eq 1 ]] || return 0

  if [[ -z "${PI_PACKAGE_DIR}" ]]; then
    return 0
  fi

  if pi_package_is_installed "${PI_PACKAGE_DIR}"; then
    return 0
  fi

  PI_PACKAGE_INSTALL_NEEDED=1
}

# --- Output and apply ---
print_no_work() {
  if [[ "${DRY_RUN}" -eq 1 ]]; then
    echo "Dry run: nothing to do."
  else
    echo "Nothing to do."
  fi
}

print_plan() {
  if [[ "${#PLAN_ACTIONS[@]}" -gt 0 ]]; then
    print_sync_plan
  fi

  if [[ "${#INSTALL_DIRS[@]}" -gt 0 ]]; then
    if [[ "${#PLAN_ACTIONS[@]}" -gt 0 ]]; then
      echo
    fi
    print_dependency_plan
  fi

  if [[ "${PI_PACKAGE_INSTALL_NEEDED}" -eq 1 ]]; then
    if [[ "${#PLAN_ACTIONS[@]}" -gt 0 || "${#INSTALL_DIRS[@]}" -gt 0 ]]; then
      echo
    fi
    print_pi_package_plan
  fi
}

print_sync_plan() {
  local total="${#PLAN_ACTIONS[@]}"
  local header

  if [[ "${DRY_RUN}" -eq 1 ]]; then
    header="Dry run: ${total} planned $(pluralize "${total}" "sync change" "sync changes")"
  else
    header="Sync changes: ${total} planned"
  fi

  echo "${header}"
  echo

  local printed_group=0
  local group
  for group in .agents Codex Claude Pi; do
    if print_sync_group "${group}" "${printed_group}"; then
      printed_group=1
    fi
  done

  echo
  echo "Summary: ${total} $(pluralize "${total}" "sync change" "sync changes") ($(sync_summary))"
}

print_sync_group() {
  local group="$1"
  local printed_any="$2"
  local group_count=0
  local index

  for index in "${!PLAN_ACTIONS[@]}"; do
    if [[ "$(classify_managed_path "${PLAN_DESTS[$index]}")" != "${group}" ]]; then
      continue
    fi

    if [[ "${group_count}" -eq 0 ]]; then
      if [[ "${printed_any}" -eq 1 ]]; then
        echo
      fi
      echo "${group}"
    fi

    local action="${PLAN_ACTIONS[$index]}"
    local dest
    dest="$(format_home_path "${PLAN_DESTS[$index]}")"

    if [[ "${action}" == "remove" ]]; then
      printf '  %-7s %s\n' "${action}" "${dest}"
    else
      local src
      src="$(format_home_path "${PLAN_SRCS[$index]}")"
      printf '  %-7s %s -> %s\n' "${action}" "${dest}" "${src}"
    fi

    group_count=$((group_count + 1))
  done

  [[ "${group_count}" -gt 0 ]]
}

print_dependency_plan() {
  local total="${#INSTALL_DIRS[@]}"
  local header

  if [[ "${DRY_RUN}" -eq 1 ]]; then
    header="Dry run: ${total} planned $(pluralize "${total}" "package setup" "package setups")"
  else
    header="Dependency setup: ${total} planned"
  fi

  echo "${header}"
  echo
  echo "Packages"

  local index
  for index in "${!INSTALL_DIRS[@]}"; do
    printf '  npm %-7s %s\n' "${INSTALL_COMMANDS[$index]}" "$(format_repo_path "${INSTALL_DIRS[$index]}")"
  done

  echo
  echo "Summary: ${total} $(pluralize "${total}" "package setup" "package setups") ($(install_summary))"
}

print_pi_package_plan() {
  local header

  if [[ "${DRY_RUN}" -eq 1 ]]; then
    header="Dry run: 1 planned Pi package install"
  else
    header="Pi package: 1 planned install"
  fi

  echo "${header}"
  echo
  printf '  pi install %s\n' "$(format_home_path "${PI_PACKAGE_DIR}")"
}

confirm_apply() {
  if [[ "${YES}" -eq 1 ]]; then
    return 0
  fi

  if [[ ! -t 0 ]]; then
    echo "error: refusing to apply changes non-interactively without --yes" >&2
    exit 2
  fi

  local answer
  read -r -p "Proceed with $(apply_summary)? [y/N] " answer

  case "${answer}" in
    y | Y | yes | YES)
      ;;
    *)
      echo "Aborted."
      exit 0
      ;;
  esac
}

preflight_apply_roots() {
  if [[ "${#PLAN_ACTIONS[@]}" -eq 0 ]]; then
    return 0
  fi

  visit_selected_target_roots prepare_directory_root
}

apply_sync_plan() {
  local index
  for index in "${!PLAN_ACTIONS[@]}"; do
    local action="${PLAN_ACTIONS[$index]}"
    local dest="${PLAN_DESTS[$index]}"
    local src="${PLAN_SRCS[$index]}"

    case "${action}" in
      remove)
        rm -rf "${dest}"
        ;;
      create | replace)
        if [[ "${action}" == "replace" ]]; then
          rm -rf "${dest}"
        fi
        mkdir -p "$(dirname "${dest}")"
        ln -sfn "${src}" "${dest}"
        ;;
      *)
        echo "error: unknown plan action: ${action}" >&2
        exit 1
        ;;
    esac
  done
}

run_dependency_setup() {
  if [[ "${#INSTALL_DIRS[@]}" -eq 0 ]]; then
    return 0
  fi

  run_package_installs
}

run_package_installs() {
  local index
  for index in "${!INSTALL_DIRS[@]}"; do
    local command="${INSTALL_COMMANDS[$index]}"
    local dir="${INSTALL_DIRS[$index]}"

    echo
    echo "==> npm ${command} in $(format_repo_path "${dir}")"
    (
      cd "${dir}"
      npm "${command}"
    )
  done
}

run_pi_package_install() {
  if [[ "${PI_PACKAGE_INSTALL_NEEDED}" -eq 0 ]]; then
    return 0
  fi

  echo
  echo "==> pi install $(format_home_path "${PI_PACKAGE_DIR}")"
  pi install "${PI_PACKAGE_DIR}"
}

print_applied_summary() {
  if [[ "${#PLAN_ACTIONS[@]}" -gt 0 ]]; then
    echo "Applied ${#PLAN_ACTIONS[@]} $(pluralize "${#PLAN_ACTIONS[@]}" "sync change" "sync changes") ($(sync_summary))."
  fi

  if [[ "${#INSTALL_DIRS[@]}" -gt 0 ]]; then
    echo "Installed ${#INSTALL_DIRS[@]} $(pluralize "${#INSTALL_DIRS[@]}" "package" "packages") ($(install_summary))."
  fi

  if [[ "${PI_PACKAGE_INSTALL_NEEDED}" -eq 1 ]]; then
    echo "Installed Pi package $(format_home_path "${PI_PACKAGE_DIR}")."
  fi
}

# --- Low-level helpers ---
usage() {
  cat <<EOF
Set up ~/.agents in selected agent configs.

Usage:
  setup [--dry-run] [--yes] [--prune] [--codex] [--claude] [--pi]

Options:
  --dry-run   Print planned sync, npm install, and Pi package install steps only
  --yes       Apply without prompting
  --prune     Remove Claude skills no longer present in Tau's skills/, stale Pi JSON symlinks,
              and the old ~/.pi/agent/extensions symlink to ~/.agents/pi/extensions
  --codex     Set up only Codex-managed files and relevant package dependencies
  --claude    Set up only Claude-managed files and relevant package dependencies
  --pi        Set up only Pi-managed files and relevant package dependencies

Environment:
  AGENTS_TAU_DIR          Override the Tau checkout path (default: ~/.agents/tau, then ${DEFAULT_TAU_HINT_DIR})
  AGENTS_PI_PACKAGE_NAME  Tau package name to install for Pi (default: ${PI_PACKAGE_NAME})

Notes:
  - If no agent flag is provided, set up Codex, Claude, and Pi.
  - ~/.agents/skills is kept as a symlink to the Tau checkout's skills/ directory.
  - Codex and Pi use ~/.agents/skills directly; Claude gets per-skill links into ~/.claude/skills.
  - Pi installs a local Tau package for extensions/themes and syncs AGENTS.md plus ~/.agents/pi/agent/*.json.
  - Uses npm ci when package-lock.json exists; otherwise uses npm install.
EOF
}

format_home_path() {
  local path="$1"

  case "${path}" in
    "${HOME}")
      printf '~'
      ;;
    "${HOME}/"*)
      printf '~/%s' "${path#"${HOME}/"}"
      ;;
    *)
      printf '%s' "${path}"
      ;;
  esac
}

format_repo_path() {
  local path="$1"

  case "${path}" in
    "${AGENTS_ROOT}")
      printf '.'
      ;;
    "${AGENTS_ROOT}/"*)
      printf '%s' "${path#"${AGENTS_ROOT}/"}"
      ;;
    *)
      printf '%s' "${path}"
      ;;
  esac
}

pluralize() {
  local count="$1"
  local singular="$2"
  local plural="${3:-${singular}s}"

  if [[ "${count}" -eq 1 ]]; then
    printf '%s' "${singular}"
  else
    printf '%s' "${plural}"
  fi
}

sync_summary() {
  local parts=()

  if [[ "${PLAN_CREATE_COUNT}" -gt 0 ]]; then
    parts+=("${PLAN_CREATE_COUNT} $(pluralize "${PLAN_CREATE_COUNT}" "addition")")
  fi

  if [[ "${PLAN_REPLACE_COUNT}" -gt 0 ]]; then
    parts+=("${PLAN_REPLACE_COUNT} $(pluralize "${PLAN_REPLACE_COUNT}" "replacement")")
  fi

  if [[ "${PLAN_REMOVE_COUNT}" -gt 0 ]]; then
    parts+=("${PLAN_REMOVE_COUNT} $(pluralize "${PLAN_REMOVE_COUNT}" "removal")")
  fi

  join_parts ", " "${parts[@]}"
}

package_install_command() {
  local package_dir="$1"

  if [[ -f "${package_dir}/package-lock.json" ]]; then
    printf 'ci'
  else
    printf 'install'
  fi
}

package_needs_setup() {
  local package_dir="$1"

  if [[ ! -f "${package_dir}/package-lock.json" ]]; then
    return 0
  fi

  local install_marker="${package_dir}/node_modules/.package-lock.json"

  if [[ ! -f "${install_marker}" ]]; then
    return 0
  fi

  if [[ "${package_dir}/package-lock.json" -nt "${install_marker}" ]]; then
    return 0
  fi

  return 1
}

install_summary() {
  local ci_count=0
  local install_count=0
  local command

  for command in "${INSTALL_COMMANDS[@]}"; do
    case "${command}" in
      ci)
        ci_count=$((ci_count + 1))
        ;;
      install)
        install_count=$((install_count + 1))
        ;;
    esac
  done

  local parts=()
  if [[ "${ci_count}" -gt 0 ]]; then
    parts+=("${ci_count} npm ci")
  fi
  if [[ "${install_count}" -gt 0 ]]; then
    parts+=("${install_count} npm install")
  fi

  join_parts ", " "${parts[@]}"
}

apply_summary() {
  local parts=()

  if [[ "${#PLAN_ACTIONS[@]}" -gt 0 ]]; then
    parts+=("${#PLAN_ACTIONS[@]} $(pluralize "${#PLAN_ACTIONS[@]}" "sync change" "sync changes")")
  fi

  if [[ "${#INSTALL_DIRS[@]}" -gt 0 ]]; then
    parts+=("${#INSTALL_DIRS[@]} $(pluralize "${#INSTALL_DIRS[@]}" "package install" "package installs")")
  fi

  if [[ "${PI_PACKAGE_INSTALL_NEEDED}" -eq 1 ]]; then
    parts+=("1 Pi package install")
  fi

  join_parts ", " "${parts[@]}"
}

join_parts() {
  local separator="$1"
  shift

  local joined=""
  local index=0
  local part
  for part in "$@"; do
    [[ -n "${part}" ]] || continue
    if [[ "${index}" -gt 0 ]]; then
      joined+="${separator}"
    fi
    joined+="${part}"
    index=$((index + 1))
  done

  printf '%s' "${joined}"
}

classify_managed_path() {
  local path="$1"

  case "${path}" in
    "${AGENTS_SKILLS_DIR}")
      printf '.agents'
      ;;
    "${CODEX_INSTRUCTIONS_FILE}")
      printf 'Codex'
      ;;
    "${CLAUDE_INSTRUCTIONS_FILE}" | "${CLAUDE_SKILLS_DIR}"/*)
      printf 'Claude'
      ;;
    "${PI_INSTRUCTIONS_FILE}" | "${PI_AGENT_DIR}"/*.json | "${PI_EXTENSIONS_DIR}")
      printf 'Pi'
      ;;
    *)
      printf 'Other'
      ;;
  esac
}

validate_directory_root() {
  local path="$1"
  local probe="${path}"

  while [[ ! -e "${probe}" ]]; do
    local parent
    parent="$(dirname "${probe}")"
    if [[ "${parent}" == "${probe}" ]]; then
      break
    fi
    probe="${parent}"
  done

  if [[ -e "${probe}" && ! -d "${probe}" ]]; then
    echo "error: expected directory root but found non-directory ancestor: $(format_home_path "${probe}")" >&2
    exit 1
  fi
}

prepare_directory_root() {
  local path="$1"

  if ! mkdir -p "${path}"; then
    echo "error: failed to prepare directory root: $(format_home_path "${path}")" >&2
    exit 1
  fi

  if [[ ! -w "${path}" ]]; then
    echo "error: directory root is not writable: $(format_home_path "${path}")" >&2
    exit 1
  fi
}

ensure_managed_path() {
  local path="$1"

  if [[ "$(classify_managed_path "${path}")" == "Other" ]]; then
    echo "error: refusing to manage unexpected path: $(format_home_path "${path}")" >&2
    exit 1
  fi
}

add_plan() {
  local action="$1"
  local dest="$2"
  local src="${3:-}"

  ensure_managed_path "${dest}"

  case "${action}" in
    create)
      PLAN_CREATE_COUNT=$((PLAN_CREATE_COUNT + 1))
      ;;
    replace)
      PLAN_REPLACE_COUNT=$((PLAN_REPLACE_COUNT + 1))
      ;;
    remove)
      PLAN_REMOVE_COUNT=$((PLAN_REMOVE_COUNT + 1))
      ;;
    *)
      echo "error: unknown plan action: ${action}" >&2
      exit 1
      ;;
  esac

  PLAN_ACTIONS+=("${action}")
  PLAN_DESTS+=("${dest}")
  PLAN_SRCS+=("${src}")
}

plan_remove() {
  add_plan remove "$1"
}

plan_link() {
  local src="$1"
  local dest="$2"
  local mode="$3"

  if [[ -L "${dest}" ]]; then
    local existing_target
    existing_target="$(readlink "${dest}")"

    if [[ "${existing_target}" == "${src}" ]]; then
      return 0
    fi

    add_plan replace "${dest}" "${src}"
    return 0
  fi

  case "${mode}" in
    dir)
      if [[ -d "${dest}" ]]; then
        add_plan replace "${dest}" "${src}"
      elif [[ -e "${dest}" ]]; then
        echo "skip: $(format_home_path "${dest}") exists and is not a directory/symlink" >&2
      else
        add_plan create "${dest}" "${src}"
      fi
      ;;
    file)
      if [[ -f "${dest}" ]]; then
        add_plan replace "${dest}" "${src}"
      elif [[ -e "${dest}" ]]; then
        echo "skip: $(format_home_path "${dest}") exists and is not a file/symlink" >&2
      else
        add_plan create "${dest}" "${src}"
      fi
      ;;
    any)
      if [[ -e "${dest}" ]]; then
        add_plan replace "${dest}" "${src}"
      else
        add_plan create "${dest}" "${src}"
      fi
      ;;
    *)
      echo "error: unknown link planning mode: ${mode}" >&2
      exit 1
      ;;
  esac
}

package_has_runtime_dependencies() {
  local package_json="$1"
  grep -q '"dependencies"[[:space:]]*:' "${package_json}"
}

ensure_runtime_dependencies() {
  if [[ "${DRY_RUN}" -eq 1 ]]; then
    return 0
  fi

  if [[ "${#INSTALL_DIRS[@]}" -gt 0 ]]; then
    require_command npm
  fi

  if [[ "${PI_PACKAGE_INSTALL_NEEDED}" -eq 1 ]]; then
    require_command pi
  fi
}

require_command() {
  local command="$1"

  if ! command -v "${command}" >/dev/null 2>&1; then
    echo "error: required command not found: ${command}" >&2
    exit 1
  fi
}

resolve_existing_path() {
  local path="$1"
  (
    cd "${path}" && pwd -P
  )
}

pi_package_is_installed() {
  local package_dir="$1"

  python3 - "$PI_SETTINGS_FILE" "$package_dir" <<'PY'
import json
import pathlib
import sys

settings_path = pathlib.Path(sys.argv[1])
target = pathlib.Path(sys.argv[2]).resolve()

if not settings_path.exists():
    raise SystemExit(1)

try:
    data = json.loads(settings_path.read_text())
except Exception:
    raise SystemExit(1)

for entry in data.get("packages", []):
    source = entry.get("source") if isinstance(entry, dict) else entry
    if not isinstance(source, str):
        continue
    try:
        resolved = pathlib.Path(source).expanduser().resolve()
    except Exception:
        continue
    if resolved == target:
        raise SystemExit(0)

raise SystemExit(1)
PY
}

main "$@"
